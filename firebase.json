{
  "hosting": {
    "public": "dist/client",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/es/dashboard/admin/groups/edit/*",
        "destination": "/es/dashboard/admin/groups/edit/index.html"
      },
      {
        "source": "/en/dashboard/admin/groups/edit/*",
        "destination": "/en/dashboard/admin/groups/edit/index.html"
      },
      {
        "source": "/es/dashboard/admin/groups/*",
        "destination": "/es/dashboard/admin/groups/detail/index.html"
      },
      {
        "source": "/en/dashboard/admin/groups/*",
        "destination": "/en/dashboard/admin/groups/detail/index.html"
      },
      {
        "source": "/es/dashboard/journal-club/edit/*",
        "destination": "/es/dashboard/journal-club/edit/index.html"
      },
      {
        "source": "/en/dashboard/journal-club/edit/*",
        "destination": "/en/dashboard/journal-club/edit/index.html"
      },
      {
        "source": "/es/dashboard/journal-club/*",
        "destination": "/es/dashboard/journal-club/detail/index.html"
      },
      {
        "source": "/en/dashboard/journal-club/*",
        "destination": "/en/dashboard/journal-club/detail/index.html"
      },
      {
        "source": "/es/dashboard/newsletter/edit/*",
        "destination": "/es/dashboard/newsletter/edit/index.html"
      },
      {
        "source": "/en/dashboard/newsletter/edit/*",
        "destination": "/en/dashboard/newsletter/edit/index.html"
      },
      {
        "source": "/es/dashboard/spotlights/edit/*",
        "destination": "/es/dashboard/spotlights/edit/index.html"
      },
      {
        "source": "/en/dashboard/spotlights/edit/*",
        "destination": "/en/dashboard/spotlights/edit/index.html"
      },
      {
        "source": "/es/dashboard/events/edit/*",
        "destination": "/es/dashboard/events/edit/index.html"
      },
      {
        "source": "/en/dashboard/events/edit/*",
        "destination": "/en/dashboard/events/edit/index.html"
      },
      {
        "source": "/es/dashboard/events/*",
        "destination": "/es/dashboard/events/detail/index.html"
      },
      {
        "source": "/en/dashboard/events/*",
        "destination": "/en/dashboard/events/detail/index.html"
      },
      {
        "source": "/es/dashboard/jobs/*",
        "destination": "/es/dashboard/jobs/detail/index.html"
      },
      {
        "source": "/en/dashboard/jobs/*",
        "destination": "/en/dashboard/jobs/detail/index.html"
      },
      {
        "source": "/es/members/*/cv",
        "destination": "/es/cv/index.html"
      },
      {
        "source": "/en/members/*/cv",
        "destination": "/en/cv/index.html"
      },
      {
        "source": "/es/members/*",
        "destination": "/es/members/profile/index.html"
      },
      {
        "source": "/en/members/*",
        "destination": "/en/members/profile/index.html"
      },
      {
        "source": "/es/companies/*",
        "destination": "/es/companies/profile/index.html"
      },
      {
        "source": "/en/companies/*",
        "destination": "/en/companies/profile/index.html"
      }
    ],
    "headers": [
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/images/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=2592000"
          }
        ]
      },
      {
        "source": "**/*.@(woff2|woff|ttf|eot)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|png|gif|svg|webp|avif|ico)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=2592000"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, must-revalidate"
          }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"],
    "source": "functions"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8088
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "singleProjectMode": true
  }
}
