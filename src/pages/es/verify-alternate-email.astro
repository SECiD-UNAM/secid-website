---
import ModernLayout from '@/layouts/ModernLayout.astro';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import VerifyAlternateEmailPage from '@/components/wrappers/VerifyAlternateEmailPage';
---

<ModernLayout
  title="Verificar correo alterno - SECiD"
  description="Verifica tu correo alterno para acceder al mismo perfil con cualquiera de tus correos."
  lang="es"
>
  <Navigation lang="es" />
  <div
    class="flex min-h-screen items-center justify-center bg-gray-50 px-4 py-12 dark:bg-gray-900 sm:px-6 lg:px-8"
  >
    <VerifyAlternateEmailPage client:only="react" lang="es" />
  </div>
  <Footer lang="es" />
</ModernLayout>
