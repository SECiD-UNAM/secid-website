---
import ModernLayout from '../../layouts/ModernLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
---

<ModernLayout
  title="Programa de Mentoría - SECiD"
  description="Conecta con mentores experimentados en ciencia de datos o conviértete en mentor para la comunidad SECiD"
  lang="es"
>
  <Navigation lang="es" />

  <main>
    <section class="secid-hero secid-hero--secondary">
      <div class="secid-hero__container">
        <div class="secid-hero__content">
          <h1 class="secid-hero__title">Programa de Mentoría</h1>
          <p class="secid-hero__subtitle">
            Conecta con mentores experimentados o guía a la próxima generación
            de científicos de datos
          </p>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="secid-section">
      <div class="secid-container">
        <div class="mentorship-header">
          <h2 class="secid-section__title">¿Cómo funciona?</h2>
          <p class="secid-section__description">
            Nuestro programa de mentoría conecta profesionales experimentados
            con miembros que buscan orientación
          </p>
        </div>

        <div class="mentorship-steps">
          <div class="mentorship-step">
            <div class="mentorship-step__icon mentorship-step__icon--primary">
              <i class="fas fa-user-plus"></i>
            </div>
            <h3 class="mentorship-step__title">1. Regístrate</h3>
            <p class="mentorship-step__text">
              Crea tu perfil como mentor o mentee y define tus áreas de interés
            </p>
          </div>

          <div class="mentorship-step">
            <div class="mentorship-step__icon mentorship-step__icon--secondary">
              <i class="fas fa-handshake"></i>
            </div>
            <h3 class="mentorship-step__title">2. Matching</h3>
            <p class="mentorship-step__text">
              Nuestro algoritmo encuentra las mejores coincidencias basado en
              habilidades, disponibilidad y objetivos
            </p>
          </div>

          <div class="mentorship-step">
            <div class="mentorship-step__icon mentorship-step__icon--gold">
              <i class="fas fa-rocket"></i>
            </div>
            <h3 class="mentorship-step__title">3. Crece</h3>
            <p class="mentorship-step__text">
              Participa en sesiones regulares, establece metas y avanza en tu
              carrera profesional
            </p>
          </div>
        </div>

        <!-- CTAs -->
        <div class="mentorship-ctas">
          <a
            href="/registro"
            class="secid-button secid-button--primary secid-button--lg"
          >
            <i class="fas fa-users"></i>
            Registrate para Participar
          </a>
          <a
            href="/es/contact"
            class="secid-button secid-button--outline secid-button--lg"
          >
            <i class="fas fa-envelope"></i>
            Contactanos
          </a>
        </div>
      </div>
    </section>

    <!-- Coming Soon -->
    <section class="secid-section mentorship-stats-section">
      <div class="secid-container">
        <div style="text-align:center; padding:2rem 0;">
          <i class="fas fa-clock" style="font-size:2rem; color:var(--secid-gold); margin-bottom:1rem; display:block;"></i>
          <h2 style="font-size:1.5rem; font-weight:700; margin-bottom:0.5rem;">Proximamente</h2>
          <p style="color:var(--color-text-secondary); max-width:500px; margin:0 auto;">
            El programa de mentoria esta en desarrollo. Registrate como miembro para ser notificado cuando este disponible.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="es" />
</ModernLayout>

<style>
  .mentorship-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .mentorship-steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .mentorship-step {
    text-align: center;
    padding: 2rem;
    background: var(--card-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
  }

  .mentorship-step__icon {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
    color: white;
    font-size: 1.5rem;
  }

  .mentorship-step__icon--primary {
    background: linear-gradient(
      135deg,
      var(--secid-primary),
      var(--secid-gold)
    );
  }

  .mentorship-step__icon--secondary {
    background: linear-gradient(
      135deg,
      var(--secid-secondary),
      var(--secid-secondary-dark)
    );
  }

  .mentorship-step__icon--gold {
    background: linear-gradient(
      135deg,
      var(--secid-gold),
      var(--secid-gold-dark)
    );
  }

  .mentorship-step__title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .mentorship-step__text {
    color: var(--color-text-secondary);
  }

  .mentorship-ctas {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .mentorship-stats-section {
    background: var(--color-surface-alt);
  }

  .mentorship-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    text-align: center;
  }

  .mentorship-stats__value {
    font-size: 2.5rem;
    font-weight: 700;
  }

  .mentorship-stats__label {
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .mentorship-steps {
      grid-template-columns: 1fr;
    }

    .mentorship-ctas {
      flex-direction: column;
    }

    .mentorship-stats {
      grid-template-columns: repeat(2, 1fr);
    }

    .mentorship-stats__value {
      font-size: 2rem;
    }
  }

  @media (max-width: 480px) {
    .mentorship-stats {
      grid-template-columns: 1fr;
    }

    .mentorship-step {
      padding: var(--space-lg);
    }
  }
</style>
