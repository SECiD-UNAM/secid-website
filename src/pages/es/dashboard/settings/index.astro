---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import SecuritySettingsPage from '@/components/wrappers/SecuritySettingsPage';
---

<DashboardLayout
  title="Configuracion - SECiD"
  description="Configura tu cuenta y preferencias de seguridad"
  lang="es"
>
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white">
      Configuracion
    </h1>
    <p class="mt-2 text-gray-600 dark:text-gray-400">
      Gestiona la seguridad y preferencias de tu cuenta
    </p>
  </div>

  <SecuritySettingsPage client:only="react" lang="es" />
</DashboardLayout>
