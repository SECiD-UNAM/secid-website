---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import AdminMembersPage from '@/components/wrappers/AdminMembersPage';
---

<DashboardLayout
  title="Member Management - SECiD"
  description="Manage SECiD community members"
  lang="en"
  requireVerified={true}
  requireRole={['admin', 'moderator']}
>
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white">
      Member Management
    </h1>
    <p class="mt-2 text-gray-600 dark:text-gray-400">
      Manage the members of the SECiD community
    </p>
  </div>

  <AdminMembersPage client:only="react" lang="en" />
</DashboardLayout>
