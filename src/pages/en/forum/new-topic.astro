---
export const prerender = false;

import ModernLayout from '../../../layouts/ModernLayout.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
import ForumPost from '../../../components/forums/ForumPost';
import { getLanguageFromUrl } from '../../../i18n/translations';

const language = getLanguageFromUrl(Astro.url);
const url = new URL(Astro.request.url);
const categorySlug = url.searchParams.get('category');

// Auth is handled client-side by ForumPost via Firebase Auth.
// The component checks authentication and shows login prompt if needed.
---

<ModernLayout
  title="New Topic - Forum - SECiD"
  description="Create a new topic in the SECiD forum"
  lang="en"
>
  <Navigation lang="en" />
  <ForumPost
    mode="create-topic"
    language={language}
    categorySlug={categorySlug ?? undefined}
    client:load
  />
  <Footer lang="en" />
</ModernLayout>
