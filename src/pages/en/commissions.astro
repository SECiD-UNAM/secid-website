---
import ModernLayout from '../../layouts/ModernLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import CommissionsPage from '../../components/wrappers/CommissionsPage';
---

<ModernLayout
  title="Commissions - SECiD"
  description="Discover how SECiD is organized and learn about our commissions"
  lang="en"
>
  <Navigation lang="en" />

  <main>
    <section class="secid-hero secid-hero--secondary">
      <div class="secid-hero__container">
        <div class="secid-hero__content">
          <h1 class="secid-hero__title">Commissions</h1>
          <p class="secid-hero__subtitle">
            Discover how our society is organized and its commissions
          </p>
        </div>
      </div>
    </section>

    <section class="secid-section">
      <div class="secid-container">
        <CommissionsPage client:load lang="en" />
      </div>
    </section>
  </main>

  <Footer lang="en" />
</ModernLayout>
