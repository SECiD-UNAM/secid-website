---
import AdminLayout from '@/layouts/AdminLayout.astro';
import AdminMergeTool from '@/components/admin/AdminMergeTool.tsx';
import AdminAuthGuard from '@/components/admin/AdminAuthGuard.tsx';

export const prerender = false;

const title = 'Fusionar Perfiles - Admin SECiD';
const description = 'Herramienta administrativa para fusionar perfiles duplicados en la plataforma SECiD';
---

<AdminLayout title={title} description={description} currentPath="/admin/merge-profiles">
  <AdminAuthGuard requiredRole="admin" client:load>
    <AdminMergeTool client:load />
  </AdminAuthGuard>
</AdminLayout>
