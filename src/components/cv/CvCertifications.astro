---
import type { CVData } from '@/types/cv';

interface Props {
  certifications: CVData['certifications'];
  lang: 'es' | 'en';
}

const { certifications, lang } = Astro.props;

const sectionTitle = lang === 'es' ? 'Certificaciones' : 'Certifications';
const viewCredentialLabel =
  lang === 'es' ? 'Ver credencial' : 'View credential';
---

<section
  id="certifications"
  class="border-t border-gray-200 py-10 dark:border-gray-800"
>
  <h2 class="mb-8 text-2xl font-bold text-gray-900 dark:text-white">
    {sectionTitle}
  </h2>

  <div class="space-y-0">
    {
      certifications.map((cert) => (
        <div class="border-b border-gray-100 py-4 last:border-b-0 dark:border-gray-800/50">
          <div class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between">
            <div class="flex-1">
              <h3 class="text-base font-semibold text-gray-900 dark:text-white">
                {cert.name}
              </h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">
                {cert.issuer}
              </p>
              {cert.credentialUrl && (
                <a
                  href={cert.credentialUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-1 inline-flex items-center gap-1 text-xs text-primary-600 transition-colors hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300"
                >
                  {viewCredentialLabel}
                  <svg
                    class="h-3 w-3"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                    />
                  </svg>
                </a>
              )}
            </div>

            <span class="flex-shrink-0 text-sm text-gray-500 dark:text-gray-400">
              {cert.date}
            </span>
          </div>
        </div>
      ))
    }
  </div>
</section>
