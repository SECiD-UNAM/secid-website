---
import type { CVData } from '@/types/cv';

interface Props {
  personal: CVData['personal'];
}

const { personal } = Astro.props;
const { name, title, location, contact, profileImage, summary } = personal;

const initials = `${name.first.charAt(0)}${name.last.charAt(0)}`.toUpperCase();
---

<section id="about" class="pb-10">
  <div class="flex flex-col-reverse gap-8 md:flex-row md:items-start">
    <!-- Text content -->
    <div class="flex-1">
      <h1
        class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white md:text-5xl"
      >
        {name.full}
      </h1>

      {
        title && (
          <p class="mt-2 text-xl text-primary-600 dark:text-primary-400">
            {title}
          </p>
        )
      }

      {
        location && (
          <div class="mt-3 flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400">
            <svg
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              />
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
              />
            </svg>
            <span>{location}</span>
          </div>
        )
      }

      {
        summary && (
          <p class="mt-6 leading-relaxed text-gray-600 dark:text-gray-300">
            {summary}
          </p>
        )
      }

      <!-- Social links -->
      <div class="mt-6 flex flex-wrap items-center gap-3">
        {
          contact.linkedin && (
            <a
              href={contact.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-gray-200 text-gray-500 transition-all hover:-translate-y-0.5 hover:border-primary-500 hover:bg-primary-500 hover:text-white dark:border-gray-700 dark:text-gray-400 dark:hover:border-primary-500"
              aria-label="LinkedIn"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
            </a>
          )
        }

        {
          contact.github && (
            <a
              href={contact.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-gray-200 text-gray-500 transition-all hover:-translate-y-0.5 hover:border-primary-500 hover:bg-primary-500 hover:text-white dark:border-gray-700 dark:text-gray-400 dark:hover:border-primary-500"
              aria-label="GitHub"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
              </svg>
            </a>
          )
        }

        {
          contact.twitter && (
            <a
              href={contact.twitter}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-gray-200 text-gray-500 transition-all hover:-translate-y-0.5 hover:border-primary-500 hover:bg-primary-500 hover:text-white dark:border-gray-700 dark:text-gray-400 dark:hover:border-primary-500"
              aria-label="Twitter"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
              </svg>
            </a>
          )
        }

        {
          contact.email && (
            <a
              href={`mailto:${contact.email}`}
              class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-gray-200 text-gray-500 transition-all hover:-translate-y-0.5 hover:border-primary-500 hover:bg-primary-500 hover:text-white dark:border-gray-700 dark:text-gray-400 dark:hover:border-primary-500"
              aria-label="Email"
            >
              <svg
                class="h-5 w-5"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                />
              </svg>
            </a>
          )
        }

        {
          contact.portfolio && (
            <a
              href={contact.portfolio}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-gray-200 text-gray-500 transition-all hover:-translate-y-0.5 hover:border-primary-500 hover:bg-primary-500 hover:text-white dark:border-gray-700 dark:text-gray-400 dark:hover:border-primary-500"
              aria-label="Portfolio"
            >
              <svg
                class="h-5 w-5"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"
                />
              </svg>
            </a>
          )
        }
      </div>
    </div>

    <!-- Profile image / initials -->
    <div class="flex flex-shrink-0 justify-center md:justify-end">
      {
        profileImage ? (
          <img
            src={profileImage}
            alt={name.full}
            class="h-32 w-32 rounded-full border-4 border-white object-cover shadow-lg dark:border-gray-800 md:h-40 md:w-40"
          />
        ) : (
          <div class="flex h-32 w-32 items-center justify-center rounded-full border-4 border-white bg-primary-100 text-3xl font-bold text-primary-700 shadow-lg dark:border-gray-800 dark:bg-primary-900/30 dark:text-primary-400 md:h-40 md:w-40 md:text-4xl">
            {initials}
          </div>
        )
      }
    </div>
  </div>
</section>
